---
import './src/styles/global.css';
import { Icon } from 'astro-icon/components';

import navData from '../data/navData';

const { pathname } = Astro.url;
---

<nav class="flex flex-row items-center justify-between bg-blue-300 h-20 px-3">
    <div class="justify-star" aria-label="Trang chủ">
        <a href="/">
            <h1 class="text-4xl font-bold bg-linear-to-r from-yellow-300 to-orange-400 bg-clip-text text-transparent ">ToolsX</h1>
        </a>    
    </div>

    <ul class="flex flex-row items-center justify-center mr-5">
        {
            navData.map(item => {
                const isActivate = pathname === item.path;
            
            return (
                <li>
                    <a href={item.path} 
                    class:list = {[ 
                        {"flex flex-row items-center p-3 cursor-pointer hover:text-white transition-colors duration-300" : !isActivate},
                        {"flex flex-row items-center p-3 cursor-pointer text-white underline" : isActivate}
                    ]}>
                        <Icon name={item.icon}/>
                        {item.name}
                    </a>
                </li>
            )}) 
        }
    </ul>
</nav>

